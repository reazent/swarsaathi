# Copy to .env and fill as you sign up (see docs/CLOUD-SETUP.md).
# The app reads only what it needs; unset integrations stay dormant.

# --- Core ---
APP_ENV=development
# Local dev (SQLite). Production: Neon/Supabase Postgres connection string.
DATABASE_URL=sqlite:///./data/indian_pitch.db
# Local: redis://localhost:6379/0 . Production: Upstash rediss:// URL.
REDIS_URL=redis://localhost:6379/0
AUDIO_DIR=audio
DATA_DIR=data

# --- Monetization ---
# Free tier: fresh pitch analyses per client per UTC day (cached lookups are free).
FREE_DAILY_ANALYSES=5
# Manual Pro grants until billing is wired (comma-separated client ids).
PRO_CLIENT_IDS=

# --- Object storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=swarsaathi-audio

# --- Observability ---
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- Auth (when charging) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- Billing (when charging) ---
REVENUECAT_PUBLIC_KEY=
REVENUECAT_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (when charging) ---
RESEND_API_KEY=

# --- Serverless GPU (when ML turns on) ---
MODAL_TOKEN=
REPLICATE_API_TOKEN=
